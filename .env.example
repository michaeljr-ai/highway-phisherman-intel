NODE_ENV=development
APP_ENV=development
PGHOST=localhost
PGPORT=5432
PGDATABASE=osint_intel
PGUSER=postgres
PGPASSWORD=postgres
PGSSL=false
OUTPUT_ROOT=./output/briefings
DEFAULT_TLP=TLP:RED
PORT=4010
PASSIVE_CLI_RECON_ENABLED=true

RBAC_ENABLED=false
RBAC_REQUIRE_KEYS=false
ZERO_TRUST_REQUIRED=false
PRIVATE_MODE=false
OWNER_ACCESS_TOKEN=replace-with-long-random-secret
RBAC_VIEWER_KEY=viewer-dev-key
RBAC_ANALYST_KEY=analyst-dev-key
RBAC_ADMIN_KEY=admin-dev-key
ALLOWED_ORIGINS=http://localhost:4010,http://127.0.0.1:4010
ALLOWLIST_IPS=
REQUEST_LIMIT_PER_MINUTE=120
SENSITIVE_REQUEST_LIMIT_PER_MINUTE=30
SECRETS_PROVIDER=env
RBAC_ROLE_KEYS_JSON={"viewer":"viewer-dev-key","analyst":"analyst-dev-key","admin":"admin-dev-key"}

EVENT_PROVIDER=none
KAFKA_BROKERS=
KAFKA_CLIENT_ID=highway-phisherman-app
KAFKA_TOPIC=intel.jobs.events
KAFKA_USERNAME=
KAFKA_PASSWORD=

OTEL_ENABLED=true
OTEL_SERVICE_NAME=highway-phisherman-app
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_LOKI_ENDPOINT=
GRAFANA_TEMPO_ENDPOINT=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
